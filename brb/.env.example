# ── Slack ──────────────────────────────────────────────────────────────────────
# Bot token (xoxb-...)  — from OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-

# App-level token (xapp-...) — from Basic Information > App-Level Tokens
# Requires connections:write scope (Socket Mode)
SLACK_APP_TOKEN=xapp-

# Channel ID where the audit summary is posted after each offboarding
SLACK_AUDIT_CHANNEL=C0000000000

# RBAC — comma-separated Slack member IDs allowed to run /offboard
# Find your ID: click your profile in Slack → ⋮ → Copy member ID
# Leave blank for local dev only; REQUIRED in production
SLACK_AUTHORIZED_USER_IDS=U01234567,U07654321

# Set to "true" to block all requests when SLACK_AUTHORIZED_USER_IDS is empty
# Automatically enabled when NODE_ENV=production
SLACK_ENFORCE_RBAC=false

# ── Anthropic / Claude ─────────────────────────────────────────────────────────
# API key from https://console.anthropic.com/
# Used to: generate LLM summaries of offboarding results, recommend follow-ups,
# and optionally parse natural-language /offboard invocations
ANTHROPIC_API_KEY=sk-ant-

# ── Google Workspace ───────────────────────────────────────────────────────────
# Service account JSON key (stringified single line) with Domain-Wide Delegation
# Required Admin SDK scopes on the service account (add in Google Admin Console):
#   https://www.googleapis.com/auth/admin.directory.user
#   https://www.googleapis.com/auth/admin.directory.user.security
#   https://www.googleapis.com/auth/admin.datatransfer
GWS_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# Super-admin email used to impersonate when calling Admin SDK
GWS_ADMIN_EMAIL=admin@yourcompany.com

# Org unit path for departed employees (must already exist in Google Admin)
GWS_DEPARTED_OU=/Departed Employees

# ── Notion ─────────────────────────────────────────────────────────────────────
# Internal integration token — from https://www.notion.so/my-integrations
NOTION_TOKEN=secret_

# Database ID — run `npm run setup:notion` to create the database and get the ID
NOTION_DATABASE_ID=
